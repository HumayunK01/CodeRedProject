# ──────────────────────────────────────────────────────────────────────────────
# Foresee — Docker Environment Variables
# Copy to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
# Then run:
#   docker compose --env-file .env.docker up --build
# ──────────────────────────────────────────────────────────────────────────────

# ── Ports (change if defaults conflict) ──────────────────────────────────────
WEB_PORT=8080
INFERENCE_PORT=8000

# ── Database (Neon PostgreSQL — cloud-hosted, no local container needed) ─────
DATABASE_URL=postgresql://username:password@host.neon.tech/database?sslmode=require

# ── Clerk Authentication ─────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com/ → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# ── Flask Backend ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_random_hex_string
DEBUG=False

# ── CORS / Frontend URL ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
ALLOWED_ORIGINS=

# ── Rate Limiting ────────────────────────────────────────────────────────────
DEFAULT_RATE_LIMIT=100 per minute
REDIS_URL=

# ── Frontend Build-time Variables ────────────────────────────────────────────
# In Docker the frontend talks to the backend via nginx reverse proxy at /api
VITE_INFER_BASE_URL=/api

# AI Chatbot (optional)
VITE_OPENROUTER_API_KEY=
VITE_CHATBOT_MODEL=openrouter/aurora-alpha

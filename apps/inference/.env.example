# OutbreakLens Flask Backend Environment Configuration
# Copy this file to .env and fill in your values

# Database (Neon PostgreSQL) - REQUIRED for database operations
DATABASE_URL=postgresql://username:password@host.neon.tech/database?sslmode=require

# Server Configuration (set by Railway/cloud host automatically)
PORT=8000
HOST=0.0.0.0

# Debug mode — MUST be False in production (True exposes Python REPL on errors!)
DEBUG=False

# Flask Secret Key — required for session security and signed tokens
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER hardcode. NEVER commit to git.
FLASK_SECRET_KEY=your_generated_secret_here

# Redis — for persistent rate limiting across workers (production required)
# Upstash: https://upstash.com | Railway: add Redis plugin | Render: add Redis service
# Format: redis://:password@host:port  or  rediss://... (TLS)
# Leave empty to use in-memory storage (single-worker dev only)
REDIS_URL=

# API Rate Limiter
# Format: "<count> per <period>"  e.g. "100 per minute", "1000 per hour"
DEFAULT_RATE_LIMIT="100 per minute"

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get both keys from https://dashboard.clerk.com/ → API Keys

# Secret key — used for Clerk Management API (admin role operations)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Publishable key — used to derive the correct per-instance JWKS URL for JWT verification
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Optional: Override JWKS URL if auto-derivation fails
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# ── CORS Trusted Origins ──────────────────────────────────────────────────────
# Dev origins (localhost:5173, localhost:3000) are always trusted automatically.
# In production, set FRONTEND_URL to your deployed frontend URL.

# Single production frontend URL (most common):
FRONTEND_URL=https://your-app.yourdomain.com

# Additional trusted origins, comma-separated (optional):
# ALLOWED_ORIGINS=https://app.yourdomain.com,https://staging.yourdomain.com
